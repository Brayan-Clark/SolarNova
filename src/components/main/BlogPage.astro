            <div x-show="page==='blog'" x-cloak>
                <!-- Liste articles -->
                <div x-show="!blogArticle">
                    <section class="pt-28 pb-20">
                        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                            <div class="text-center mb-14">
                                <span
                                    class="text-sol-500 font-display font-600 text-sm tracking-widest uppercase"
                                    >Blog & Ressources</span
                                >
                                <h1
                                    class="font-display font-900 text-4xl sm:text-5xl mt-3 mb-4"
                                >
                                    Articles & Conseils Solaires
                                </h1>
                                <p class="text-sol-200/50 max-w-xl mx-auto">
                                    Restez informé sur les dernières tendances,
                                    conseils pratiques et actualités du monde de
                                    l'énergie renouvelable.
                                </p>
                            </div>
                            <div
                                class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6"
                            >
                                <template x-for="a in articles" :key="a.id">
                                    <article
                                        class="glass glass-hover rounded-2xl overflow-hidden cursor-pointer group"
                                        @click="openArticle(a)"
                                    >
                                        <div
                                            class="h-48 overflow-hidden relative"
                                        >
                                            <img
                                                :src="a.image"
                                                :alt="a.title"
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                                loading="lazy"
                                            />
                                            <div
                                                class="absolute inset-0 bg-gradient-to-t from-sol-950/80 to-transparent"
                                            ></div>
                                            <span
                                                class="absolute bottom-3 left-3 text-xs text-sol-100 font-medium bg-sol-500/80 backdrop-blur-sm px-2.5 py-1 rounded-full"
                                                x-text="a.category"
                                            ></span>
                                        </div>
                                        <div class="p-5">
                                            <div
                                                class="text-xs text-sol-300/40 mb-3"
                                                x-text="a.date"
                                            ></div>
                                            <h2
                                                class="font-display font-700 text-lg mb-2 group-hover:text-sol-400 transition-colors leading-snug"
                                                x-text="a.title"
                                            ></h2>
                                            <p
                                                class="text-sol-200/45 text-sm leading-relaxed line-clamp-3"
                                                x-text="a.excerpt"
                                            ></p>
                                            <div
                                                class="mt-4 text-sol-400 text-sm font-medium inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all"
                                            >
                                                Lire l'article
                                                <i
                                                    class="fa-solid fa-arrow-right text-xs"
                                                ></i>
                                            </div>
                                        </div>
                                    </article>
                                </template>
                            </div>
                        </div>
                    </section>
                </div>
                <!-- Détail article -->
                <div
                    x-show="blogArticle"
                    x-transition:enter="transition ease-out duration-400"
                    x-transition:enter-start="opacity-0"
                    x-transition:enter-end="opacity-100"
                >
                    <section class="pt-28 pb-20" x-show="blogArticle">
                        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
                            <button
                                @click="blogArticle=null"
                                class="text-sol-400 text-sm font-medium cursor-pointer hover:text-sol-300 transition-colors inline-flex items-center gap-2 mb-8"
                            >
                                <i class="fa-solid fa-arrow-left text-xs"></i>
                                Retour aux articles
                            </button>
                            <template x-if="blogArticle">
                                <div>
                                    <div class="flex items-center gap-3 mb-4">
                                        <span
                                            class="text-xs text-sol-100 font-medium bg-sol-500/20 px-3 py-1 rounded-full"
                                            x-text="blogArticle.category"
                                        ></span>
                                        <span
                                            class="text-xs text-sol-300/40"
                                            x-text="blogArticle.date"
                                        ></span>
                                        <span
                                            class="text-xs text-sol-300/40"
                                            x-text="blogArticle.readTime"
                                        ></span>
                                    </div>
                                    <h1
                                        class="font-display font-900 text-3xl sm:text-4xl leading-tight mb-6"
                                        x-text="blogArticle.title"
                                    ></h1>
                                    <div
                                        class="h-64 sm:h-80 rounded-2xl overflow-hidden mb-8"
                                    >
                                        <img
                                            :src="blogArticle.image"
                                            :alt="blogArticle.title"
                                            class="w-full h-full object-cover"
                                            loading="lazy"
                                            decoding="async"
                                        />
                                    </div>
                                    <div
                                        class="article-content max-w-none text-sol-200/70 leading-relaxed"
                                        x-html="renderArticle(blogArticle.content)"
                                    ></div>
                                </div>
                            </template>
                        </div>
                    </section>
                </div>
            </div>

            <!-- ==================== AVIS ==================== -->
