# ============================================================
#  SolarNova — variables d'environnement
# ============================================================
# Copiez ce fichier en ".env" puis renseignez vos clés Supabase.
# L'application FONCTIONNE SANS ces clés : tant qu'elles sont
# absentes, les fonctionnalités base de données affichent un
# simple message d'information (aucun plantage).
#
# Le préfixe PUBLIC_ est OBLIGATOIRE : c'est ce qui rend la
# variable accessible côté navigateur (Astro / Vite).
# ------------------------------------------------------------

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- Anti-bot Cloudflare Turnstile (optionnel) ---------------
# Clé de SITE (publique). Si vide, aucun widget anti-bot n'est
# affiché et les formulaires fonctionnent normalement.
PUBLIC_TURNSTILE_SITE_KEY=

# --- Soumission sécurisée via Edge Function (optionnel) ------
# URL de l'Edge Function "submit". Si définie, toutes les écritures
# (avis, contacts, devis) passent par elle : vérification Turnstile
# côté serveur + écriture via service_role. Sinon, insertion directe
# via la clé anon (protégée par le RLS).
# ex. https://xxxx.supabase.co/functions/v1/submit
PUBLIC_SUBMIT_ENDPOINT=

# ============================================================
#  ⚠️  SECRETS CÔTÉ SERVEUR — PAS dans ce fichier !
# ============================================================
# Les variables ci-dessous ne sont PAS des variables de front.
# Elles vivent dans l'Edge Function Supabase et se définissent avec :
#   supabase secrets set NOM=valeur
# Ne JAMAIS les préfixer par PUBLIC_ ni les mettre dans le navigateur.
#
#   TURNSTILE_SECRET_KEY   clé SECRÈTE Turnstile (vérif anti-bot serveur)
#   RESEND_API_KEY         clé API Resend (envoi d'email)
#   NOTIFY_TO              email qui reçoit les demandes (ex. toi@solarnova.ml)
#   NOTIFY_FROM            expéditeur vérifié sur Resend (ex. site@tondomaine.com)
# ============================================================
